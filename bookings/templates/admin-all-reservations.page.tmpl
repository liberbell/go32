{{template "admin" .}}

{{define "page-title"}}
    All reservations
{{end}}

{{define "content"}}
    <div class="col-md-12">
        {{$res := index .Data "reservations"}}

        <table class="table table-striped table-hover" id="all-res">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Last Name</th>
                    <th>Room</th>
                    <th>Arrival</th>
                </tr>
            </thead>
        </table>
        {{range $res}}
            {{.ID}} <br>
        {{end}}
    </div>
{{end}}