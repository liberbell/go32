{{template "admin" .}}

{{define "page-title"}}
    All reservations
{{end}}

{{define "content"}}
    <div class="col-md-12">
        {{$res := index .Data "reservations"}}

        <table class="table table-striped table-hover" id="all-res">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Last Name</th>
                    <th>Room</th>
                    <th>Arrival</th>
                    <th>Departure</th>
                </tr>
            </thead>
            <tbody>
                {{range $res}}
                    <tr>
                        <td>{{.ID}}</td>
                        <td>{{.LastName}}</td>
                        <td>{{.Room}}</td>
                        <td>{{.ID}}</td>
                        <td>{{.ID}}</td>
                    </tr>
                    {{.ID}} <br>
                {{end}}
            </tbody>
        </table>
    </div>
{{end}}