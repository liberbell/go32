{{template "admin" .}}

{{define "page-title"}}
    Reservation calendar
{{end}}

{{define "content"}}
    <div class="col-md-12">
        <div class="text-center">
            <h3>{{index .StringMap "this_month"}} {{index .StringMap "this_month_year"}}</h3>
        </div>

        <div class="float-left">
            <a href="/admin/reservations-calendar?y={{index .StringMap "last_month_year"}}&m={{index .StringMap "last_month"}}" class="btn btn-sm btn-outline-secondary">&lt;&lt;</a>
        </div>
        <div class="float-right">

        </div>
        <div class="clearfix"></div>
    </div>
{{end}}